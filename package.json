{
  "name": "pitopi",
  "version": "1.0.0",
  "description": "Secure Peer-to-Peer Chat Application with Firebase Authentication",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "npx tsx src/server.ts",
    "build": "tsc && node ./scripts/copy-app.js",
    "start": "node dist/src/server.js",
    "watch": "npx ts-node-dev --respawn server.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "p2p",
    "chat",
    "webrtc",
    "socket.io",
    "firebase",
    "secure-messaging"
  ],
  "author": "Pitopi Team",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "multer": "^2.0.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/socket.io": "^3.0.1",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pitopichat/pitopi.git"
  },
  "bugs": {
    "url": "https://github.com/pitopichat/pitopi/issues"
  }
}
